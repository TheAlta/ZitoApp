# FastAPI
APP_NAME=Zito
APP_ENV=local
AUTO_CREATE_TABLES=true

# PostgreSQL
DATABASE_URL=postgresql+psycopg://zito_app:CHANGE_ME@localhost:5432/zito_app

# Arvancloud AIaaS
# Keep the real key only in .env. Never commit it.
ARVAN_API_BASE_URL=https://arvancloudai.ir/gateway/models/GPT-5.4-Mini/YOUR_ENDPOINT_TOKEN/v1
ARVAN_API_KEY=replace_with_real_api_key
ARVAN_MODEL=GPT-5.4-Mini
ARVAN_TIMEOUT_SECONDS=45

# For local development without spending tokens.
ARVAN_MOCK_AI=false

# Admin panel access. Change this before sharing the app.
ADMIN_USERNAME=zito_admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace_with_long_random_secret
ADMIN_SESSION_DAYS=3650
